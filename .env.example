# Copy this file to .env and fill in local values.
# .env is ignored by git.

# LLM API configuration
DEEPSEEK_API_KEY=your-api-key-here
ANTHROPIC_MODEL=glm-4.7
DEEPSEEK_BASE_URL=https://open.bigmodel.cn/api/anthropic

# Optional proxy settings, if needed by your local API route
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# Local toolchain paths
CLANG_PATH=/path/to/clang
SOURCE_FILE=./TSVC_2/src/tsvc.c
MAX_ROUNDS=3
